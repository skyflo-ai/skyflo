{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "engine": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "secrets": {
          "type": "object",
          "additionalProperties": true,
          "required": ["llmModel"],
          "properties": {
            "llmModel": {
              "type": "string",
              "minLength": 1,
              "description": "LLM provider and model identifier, for example gemini/gemini-2.5-pro."
            }
          }
        }
      }
    }
  }
}
