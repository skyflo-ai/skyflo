# ──────────────────────────────────────────────
# Skyflo UI - Environment Configuration
# ──────────────────────────────────────────────

# Application
NEXT_PUBLIC_APP_NAME="Skyflo Command Center"
NEXT_PUBLIC_APP_VERSION=0.0.0-dev
NODE_ENV=production

# API
API_URL=http://skyflo-engine:8080/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_FEEDBACK=false
