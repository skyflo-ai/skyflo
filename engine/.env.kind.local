# Application Settings
APP_NAME=Skyflo.ai API
APP_VERSION=0.1.0
DEBUG=false
API_V1_STR=/api/v1
ENV=production

# Server Settings
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
ENGINE_SERVER_WORKERS=1

# CORS Settings
CORS_ORIGINS=["http://skyflo-ui:3000","http://skyflo-ui.skyflo-system:3000","http://skyflo-api:8080","http://skyflo-api.skyflo-system:8080"]
CORS_CREDENTIALS=true
CORS_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_HEADERS=["*"]

# Database Settings (using postgres:// for Tortoise ORM)
DATABASE_URL=postgres://skyflo:skyflo@skyflo-postgres:5432/skyflo
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Settings
REDIS_URL=redis://skyflo-redis:6379/0

# Rate Limiting
RATE_LIMITING_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# JWT Settings
JWT_SECRET=karan@skyflo.ai
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI Settings
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_EXECUTOR_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=0

# MCP Server Settings
MCP_SERVER_URL=http://skyflo-mcp:8081
MCP_SERVER_TIMEOUT=60

# Workflow Settings
WORKFLOW_EXECUTION_TIMEOUT=300
WORKFLOW_MAX_RETRIES=3 