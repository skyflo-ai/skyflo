# ──────────────────────────────────────────────
# Skyflo Engine - Environment Configuration
# ──────────────────────────────────────────────

# Application
APP_NAME="Skyflo Engine"
APP_VERSION=0.0.0-dev
APP_DESCRIPTION="Core engine for Skyflo"
DEBUG=false
API_V1_STR=/api/v1

# Logging
LOG_LEVEL=INFO

# Database
POSTGRES_DATABASE_URL=postgres://skyflo:skyflo@skyflo-postgres:5432/skyflo

# Cache
REDIS_URL=redis://skyflo-redis:6379/0

# MCP Server
MCP_SERVER_URL=http://skyflo-mcp:8888/mcp

# Rate Limiting
RATE_LIMITING_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Authentication
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# LLM Configuration
# ──────────────────────────────────────────────

# Model identifier in provider/model format (see https://skyflo.ai/docs/llm-providers for supported providers)
LLM_MODEL=gemini/gemini-2.5-pro
# GROQ_API_KEY=
# LLM_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct
# LLM_MODEL=ollama/llama3.1:8b
GEMINI_API_KEY=your-gemini-api-key

# Base URL for self-hosted LLM endpoints (e.g., Ollama). Leave unset for cloud providers.
# LLM_HOST=http://localhost:11434

# Maximum agent loop iterations before the run is force-stopped (default: 25)
LLM_MAX_ITERATIONS=25

# Max messages kept in the LLM context window per turn (default: 40).
# Increase for long-running troubleshooting sessions where older tool
# results need to remain in context.
LLM_CONTEXT_WINDOW_MESSAGES=40

# Cap on max_tokens sent per LLM request. Leave unset for provider defaults.
# LLM_MAX_TOKENS=16384

# ──────────────────────────────────────────────
# Reasoning / Extended Thinking
# ──────────────────────────────────────────────

# Override auto-detected reasoning effort: low | medium | high
# LLM_REASONING_EFFORT=high

# Thinking budget in tokens (Anthropic only). Leave unset for provider default.
# LLM_THINKING_BUDGET_TOKENS=10000

# ──────────────────────────────────────────────
# Integrations
# ──────────────────────────────────────────────

# Kubernetes namespace where provider API keys and integration secrets are stored
INTEGRATIONS_SECRET_NAMESPACE=skyflo
